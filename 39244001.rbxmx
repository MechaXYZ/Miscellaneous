			<Item class="Script" referent="RBX222">
				<Properties>
					<bool name="Disabled">false</bool>
					<Content name="LinkedSource"><null></null></Content>
					<string name="Name">SafeScript</string>
					<ProtectedString name="Source">local plate = script.AreaShield.Plate
plate.Value = script.Parent

function onTouched(part)

	local h = part.Parent:findFirstChild(&quot;Humanoid&quot;)

	if h~=nil then
		if (h.Parent:FindFirstChild(&quot;AreaShield&quot;) == nil) then
			local a = script.AreaShield:Clone()
			a.Disabled = false
			a.Parent = h.Parent
		end
	end


end



script.Parent.Touched:connect(onTouched)</ProtectedString>
					<bool name="archivable">true</bool>
				</Properties>
				<Item class="Script" referent="RBX223">
					<Properties>
						<bool name="Disabled">true</bool>
						<Content name="LinkedSource"><null></null></Content>
						<string name="Name">AreaShield</string>
						<ProtectedString name="Source">f = Instance.new(&quot;ForceField&quot;)
f.Parent = script.Parent
safeplate = script.Plate.Value

while true do
	wait(.5)
	if (script.Parent:FindFirstChild(&quot;Torso&quot;) ~= nil) then
		if ((script.Parent.Torso.Position - safeplate.Position).magnitude &gt; 12) then break end
	else
		break
	end

end

f:Remove()
script:Remove()


</ProtectedString>
