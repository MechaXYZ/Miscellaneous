	<Item class="Script" referent="RBX546">
		<Properties>
			<bool name="Disabled">false</bool>
			<Content name="LinkedSource"><null></null></Content>
			<string name="Name">Regenerate</string>
			<ProtectedString name="Source">model = game.Workspace.SwordsP


backup = model:clone()

while true do
	wait(45)


	model:remove()



	model = backup:clone()
	model.Parent = game.Workspace
	model:makeJoints()

end
</ProtectedString>
